# ── Infrastructure ────────────────────────────────────────────────────────────

POSTGRES_DB=haritailesi
POSTGRES_USER=haritailesi
POSTGRES_PASSWORD=change-me-strong-password

REDIS_PASSWORD=change-me-strong-password

MINIO_ROOT_USER=haritailesi
MINIO_ROOT_PASSWORD=change-me-strong-password

# ── API — Auth ────────────────────────────────────────────────────────────────

JWT_SECRET=change-me-at-least-64-random-chars
JWT_REFRESH_SECRET=change-me-at-least-64-random-chars-different-from-above

# ── API — Email (Brevo) ───────────────────────────────────────────────────────

BREVO_API_KEY=your-brevo-api-key
EMAIL_FROM=noreply@haritailesi.org
EMAIL_FROM_NAME=Haritailesi

# ── API — MinIO (S3) ──────────────────────────────────────────────────────────

MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=haritailesi
MINIO_SECRET_KEY=change-me-strong-password
MINIO_BUCKET=haritailesi

# ── API — SSO ─────────────────────────────────────────────────────────────────
# docker-compose.yml'de default olarak ayarlandı; override etmek için buraya ekle:
# COOKIE_DOMAIN=.haritailesi.org
# CORS_ORIGINS=https://haritailesi.org,https://sahne.haritailesi.org,https://mutfak.haritailesi.org,https://admin.haritailesi.org
# COOKIE_SECURE=true          # Production'da mutlaka true; dev'de false (localhost)
# COOKIE_SAMESITE=lax         # lax (default) | strict | none (none → Secure=true gerektirir)

# ── Next.js Apps ──────────────────────────────────────────────────────────────

NEXT_PUBLIC_API_URL=https://api.haritailesi.org
NEXT_PUBLIC_WEB_URL=https://haritailesi.org
NEXT_PUBLIC_MUTFAK_URL=https://mutfak.haritailesi.org
NEXT_PUBLIC_SAHNE_URL=https://sahne.haritailesi.org

# ── Web Push VAPID ────────────────────────────────────────────────────────────
# Oluşturmak için: node -e "const wp=require('web-push'); console.log(wp.generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Hata izleme (opsiyonel) ───────────────────────────────────────────────────
GLITCHTIP_DSN=
