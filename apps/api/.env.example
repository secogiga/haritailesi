# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/haritailesi

# Redis
REDIS_URL=redis://localhost:6379

# JWT — her biri güçlü, rastgele bir string olmalı
JWT_SECRET=change-me-at-least-32-chars
JWT_REFRESH_SECRET=change-me-at-least-32-chars

# MinIO (S3-uyumlu)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=haritailesi

# Brevo (transactional email)
BREVO_API_KEY=your-brevo-api-key

# Web Push VAPID — üretmek için: node -e "const wp=require('web-push'); console.log(wp.generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Hata izleme (opsiyonel)
GLITCHTIP_DSN=

# Uygulama ortamı
NODE_ENV=development
PORT=3000

# SSO — Shared cookie domain
# Production: COOKIE_DOMAIN=.haritailesi.org
# Development: boş bırak (localhost cookie'leri port farkına rağmen paylaşır)
COOKIE_DOMAIN=

# CORS — virgülle ayrılmış izinli origin listesi
# Production: https://sahne.haritailesi.org,https://mutfak.haritailesi.org,https://haritailesi.org,https://admin.haritailesi.org
# Development: aşağıdaki değer varsayılandır, .env.local'da değiştirebilirsin
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003

# Hesap aktivasyon e-postasındaki şifre belirleme linki için kullanılır
# production'da NEXT_PUBLIC_WEB_URL ile aynı olmalı
NEXT_PUBLIC_WEB_URL=http://localhost:3001
