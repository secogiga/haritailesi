{
  "extends": "@haritailesi/config-ts/nestjs",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "exactOptionalPropertyTypes": false,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "ts-node": {
    "transpileOnly": true,
    "files": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "test"]
}
