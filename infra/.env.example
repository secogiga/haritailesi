# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=haritailesi
POSTGRES_USER=haritailesi
POSTGRES_PASSWORD=changeme_strong_password

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis_password
REDIS_URL=redis://:changeme_redis_password@localhost:6379

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=changeme_minio_user
MINIO_ROOT_PASSWORD=changeme_minio_password
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=haritailesi

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=changeme_jwt_secret_minimum_32_chars
JWT_REFRESH_SECRET=changeme_jwt_refresh_secret_minimum_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Database URL ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://haritailesi:changeme_strong_password@localhost:5432/haritailesi

# ─── Email (Brevo) ────────────────────────────────────────────────────────────
BREVO_API_KEY=changeme_brevo_api_key
EMAIL_FROM=noreply@haritailesi.org
EMAIL_FROM_NAME=Haritailesi

# ─── Error Tracking (GlitchTip — self-hosted) ────────────────────────────────
GLITCHTIP_DSN=

# ─── URLs ─────────────────────────────────────────────────────────────────────
APP_URL=https://haritailesi.org
SAHNE_URL=https://sahne.haritailesi.org
MUTFAK_URL=https://mutfak.haritailesi.org
ADMIN_URL=https://admin.haritailesi.org
API_URL=https://api.haritailesi.org

# Frontend public env vars (build-time)
NEXT_PUBLIC_API_URL=https://api.haritailesi.org
NEXT_PUBLIC_WEB_URL=https://haritailesi.org
NEXT_PUBLIC_SAHNE_URL=https://sahne.haritailesi.org
NEXT_PUBLIC_MUTFAK_URL=https://mutfak.haritailesi.org

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://haritailesi.org,https://sahne.haritailesi.org,https://mutfak.haritailesi.org,https://admin.haritailesi.org
